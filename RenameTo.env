# Copy this file to .env and fill in your values.

# Required: your bot's token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Optional: enables the /stats command (free key from https://www.api-football.com/)
API_FOOTBALL_KEY=

# Optional: a guild (server) ID to sync slash commands to instantly during
# development. Without it, commands sync globally and can take up to an hour
# to show up in Discord.
DEV_GUILD_ID=

# Optional: how often (in seconds) the bot re-checks subscriptions for updates.
POLL_INTERVAL=300

# Optional: post a kickoff reminder when a subscribed team's match is within
# this many hours.
REMINDER_HOURS=48

# Optional: where the SQLite database lives (defaults to src/sportsbot.db).
# Point this at a mounted volume in hosted deployments, e.g. /data/sportsbot.db
# SPORTSBOT_DB=
